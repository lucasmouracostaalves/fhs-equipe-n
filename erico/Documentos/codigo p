fatorial = 1

while True:
    qtd = int(input("Digite a quantidade de produtos distintos do kit: "))

    if qtd < 0:
        print("Erro: não são permitidos números negativos. Tente novamente.")
    else:
        break

for i in range(1, qtd + 1):
    fatorial = fatorial * i

print("As formas distintas são ao todo", fatorial)